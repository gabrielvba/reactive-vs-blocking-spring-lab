.venv/

# Local Claude/Cursor artifacts
.claude/

# Docker
.dockerignore

# OS
.DS_Store
Thumbs.db

# Grafana
infra/grafana/dashboards/*.json.backup

# Prometheus data
prometheus-data/

# Experiment results
results/

# k6 + Prometheus exported artifacts
results/k6-exports/
results/prometheus-exports/
tests/results/

# Node modules (if any frontend)
node_modules/

# Spring Initializr / IDE extras
consumers/ms-files-managment/HELP.md
.apt_generated
.factorypath
.springBeans
.sts4-cache

# Allow nested build dirs inside src if needed
!**/src/main/**/target/
!**/src/test/**/target/

# Analysis artifacts (generated by Python pipeline)
# Keep the generated checkpoint artifacts versioned, while ignoring any other
# temporary/unexpected files that may be produced by the pipeline.
analise/datasets/*
!analise/datasets/**/*.csv
analise/relatorios/*
!analise/relatorios/**/*.html
!analise/relatorios/**/*.md

# Accidental local/debug error dumps
app/**/error.txt

